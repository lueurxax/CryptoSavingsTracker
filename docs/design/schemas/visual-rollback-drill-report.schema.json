{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptosavingstracker.local/schemas/visual-rollback-drill-report.schema.json",
  "title": "Visual Rollback Drill Report",
  "type": "object",
  "required": [
    "reportVersion",
    "evidenceType",
    "wave",
    "executedAt",
    "runbookPath",
    "slaBusinessDaysMax",
    "slaBusinessDaysActual",
    "checklist",
    "telemetryMarkers",
    "evidenceLinks"
  ],
  "additionalProperties": false,
  "properties": {
    "reportVersion": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "evidenceType": {
      "const": "visual-rollback-drill-report"
    },
    "wave": {
      "type": "string",
      "pattern": "^wave[0-9]+$"
    },
    "executedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "runbookPath": {
      "type": "string",
      "minLength": 1
    },
    "slaBusinessDaysMax": {
      "type": "number",
      "minimum": 0
    },
    "slaBusinessDaysActual": {
      "type": "number",
      "minimum": 0
    },
    "checklist": {
      "type": "object",
      "required": [
        "regressionConfirmed",
        "flagsDisabled",
        "fallbackValidated",
        "communicationSent",
        "postmortemPlanned"
      ],
      "additionalProperties": false,
      "properties": {
        "regressionConfirmed": { "type": "boolean" },
        "flagsDisabled": { "type": "boolean" },
        "fallbackValidated": { "type": "boolean" },
        "communicationSent": { "type": "boolean" },
        "postmortemPlanned": { "type": "boolean" }
      }
    },
    "telemetryMarkers": {
      "type": "object",
      "required": ["triggeredEvent", "completedEvent", "markerTimestamp"],
      "additionalProperties": false,
      "properties": {
        "triggeredEvent": {
          "type": "string",
          "minLength": 1
        },
        "completedEvent": {
          "type": "string",
          "minLength": 1
        },
        "markerTimestamp": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
        }
      }
    },
    "evidenceLinks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
