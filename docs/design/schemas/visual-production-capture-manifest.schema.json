{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptosavingstracker.local/schemas/visual-production-capture-manifest.schema.json",
  "title": "Visual Production Capture Manifest",
  "type": "object",
  "required": [
    "manifestVersion",
    "updatedAt",
    "captureMode",
    "captureEntrypoints",
    "evidenceCommitSha",
    "capturedAt",
    "requiredFlows"
  ],
  "additionalProperties": false,
  "properties": {
    "manifestVersion": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "updatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "captureMode": {
      "const": "production-flow"
    },
    "captureEntrypoints": {
      "type": "object",
      "required": ["ios", "android"],
      "additionalProperties": false,
      "properties": {
        "ios": { "type": "string", "minLength": 1 },
        "android": { "type": "string", "minLength": 1 }
      }
    },
    "evidenceCommitSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "capturedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "requiredFlows": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["flowId", "routeId", "requiredStates", "states"],
        "additionalProperties": false,
        "properties": {
          "flowId": {
            "type": "string",
            "enum": ["planning", "dashboard", "settings"]
          },
          "routeId": {
            "type": "string",
            "minLength": 1
          },
          "requiredStates": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "string",
              "enum": ["default", "error", "recovery"]
            }
          },
          "states": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "object",
              "required": ["stateId", "iosArtifact", "androidArtifact"],
              "additionalProperties": false,
              "properties": {
                "stateId": {
                  "type": "string",
                  "enum": ["default", "error", "recovery"]
                },
                "iosArtifact": {
                  "type": "string",
                  "pattern": "\\.(png|jpg|jpeg|webp)$"
                },
                "androidArtifact": {
                  "type": "string",
                  "pattern": "\\.(png|jpg|jpeg|webp)$"
                }
              }
            }
          }
        }
      }
    }
  }
}
