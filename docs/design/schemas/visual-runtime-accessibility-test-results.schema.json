{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptosavingstracker.local/schemas/visual-runtime-accessibility-test-results.schema.json",
  "title": "Visual Runtime Accessibility Test Results",
  "type": "object",
  "required": [
    "reportVersion",
    "evidenceType",
    "sourceMode",
    "testMode",
    "requiredTestMode",
    "generatedAt",
    "provenance",
    "executedTests",
    "platforms"
  ],
  "additionalProperties": false,
  "properties": {
    "reportVersion": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "evidenceType": {
      "const": "runtime-accessibility-test-results"
    },
    "sourceMode": {
      "type": "string",
      "enum": ["test-run", "fixture"]
    },
    "testMode": {
      "type": "string",
      "enum": ["smoke", "full"]
    },
    "requiredTestMode": {
      "type": "string",
      "enum": ["smoke", "full"]
    },
    "generatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "provenance": {
      "type": "object",
      "required": ["commitSha", "ciJobId", "capturedAt", "testBundleHash"],
      "additionalProperties": false,
      "properties": {
        "commitSha": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "ciJobId": {
          "type": "string",
          "minLength": 1
        },
        "capturedAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
        },
        "testBundleHash": {
          "type": "string",
          "pattern": "^[0-9a-f]{32,128}$"
        }
      }
    },
    "executedTests": {
      "type": "object",
      "required": ["ios", "android", "total"],
      "additionalProperties": false,
      "properties": {
        "ios": { "type": "integer", "minimum": 0 },
        "android": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 1 }
      }
    },
    "platforms": {
      "type": "object",
      "required": ["ios", "android"],
      "additionalProperties": false,
      "properties": {
        "ios": {
          "$ref": "#/$defs/platformTestResults"
        },
        "android": {
          "$ref": "#/$defs/platformTestResults"
        }
      }
    }
  },
  "$defs": {
    "platformTestResults": {
      "type": "object",
      "required": ["runner", "suiteId", "testCommand", "executedTestCount", "allPassed", "scenarios"],
      "additionalProperties": false,
      "properties": {
        "runner": {
          "type": "string",
          "enum": ["xctest-ui", "android-instrumentation"]
        },
        "suiteId": {
          "type": "string",
          "minLength": 1
        },
        "testCommand": {
          "type": "string",
          "minLength": 1
        },
        "executedTestCount": {
          "type": "integer",
          "minimum": 1
        },
        "allPassed": {
          "type": "boolean"
        },
        "scenarios": {
          "type": "array",
          "minItems": 3,
          "items": {
            "$ref": "#/$defs/scenario"
          }
        }
      }
    },
    "scenario": {
      "type": "object",
      "required": ["flowId", "passed", "assertions"],
      "additionalProperties": false,
      "properties": {
        "flowId": {
          "type": "string",
          "enum": ["planning", "dashboard", "settings"]
        },
        "passed": {
          "type": "boolean"
        },
        "assertions": {
          "type": "object",
          "required": [
            "screenReaderLabels",
            "focusOrder",
            "contrast",
            "reducedMotion",
            "nonColorSemantics"
          ],
          "additionalProperties": false,
          "properties": {
            "screenReaderLabels": { "type": "boolean" },
            "focusOrder": { "type": "boolean" },
            "contrast": { "type": "boolean" },
            "reducedMotion": { "type": "boolean" },
            "nonColorSemantics": { "type": "boolean" }
          }
        }
      }
    }
  }
}
