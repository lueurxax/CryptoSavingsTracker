{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptosavingstracker.local/schemas/visual-performance-report.schema.json",
  "title": "Visual Performance Report",
  "type": "object",
  "required": [
    "reportVersion",
    "evidenceType",
    "wave",
    "evaluatedAt",
    "baseline",
    "current",
    "deltas",
    "thresholds",
    "traces"
  ],
  "additionalProperties": false,
  "properties": {
    "reportVersion": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "evidenceType": {
      "const": "visual-performance-report"
    },
    "wave": {
      "type": "string",
      "pattern": "^wave[0-9]+$"
    },
    "evaluatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "baseline": {
      "$ref": "#/$defs/perfMetrics"
    },
    "current": {
      "$ref": "#/$defs/perfMetrics"
    },
    "deltas": {
      "type": "object",
      "required": ["p95RegressionPercent", "jankDeltaPercentagePoints"],
      "additionalProperties": false,
      "properties": {
        "p95RegressionPercent": {
          "type": "number"
        },
        "jankDeltaPercentagePoints": {
          "type": "number"
        }
      }
    },
    "thresholds": {
      "type": "object",
      "required": ["p95RegressionMaxPercent", "jankDeltaMaxPercentagePoints"],
      "additionalProperties": false,
      "properties": {
        "p95RegressionMaxPercent": {
          "type": "number",
          "minimum": 0
        },
        "jankDeltaMaxPercentagePoints": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "traces": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/trace"
      }
    }
  },
  "$defs": {
    "perfMetrics": {
      "type": "object",
      "required": ["p95FrameTimeMs", "jankRatePercent"],
      "additionalProperties": false,
      "properties": {
        "p95FrameTimeMs": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "jankRatePercent": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "trace": {
      "type": "object",
      "required": ["platform", "device", "tool", "artifactRef"],
      "additionalProperties": false,
      "properties": {
        "platform": {
          "type": "string",
          "enum": ["ios", "android"]
        },
        "device": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "artifactRef": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
