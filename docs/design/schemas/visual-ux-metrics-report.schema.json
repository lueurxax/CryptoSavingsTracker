{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptosavingstracker.local/schemas/visual-ux-metrics-report.schema.json",
  "title": "Visual UX Metrics Report",
  "type": "object",
  "required": [
    "reportVersion",
    "wave",
    "evaluatedAt",
    "sample",
    "confidence",
    "metrics"
  ],
  "additionalProperties": false,
  "properties": {
    "reportVersion": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "wave": {
      "type": "string",
      "minLength": 1
    },
    "evaluatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "sample": {
      "type": "object",
      "required": ["participants", "scenarioTasks"],
      "additionalProperties": false,
      "properties": {
        "participants": {
          "type": "integer",
          "minimum": 0
        },
        "scenarioTasks": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "confidence": {
      "type": "object",
      "required": ["levelPercent"],
      "additionalProperties": false,
      "properties": {
        "levelPercent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": [
        "statusComprehensionTime",
        "shortfallActionAccuracy",
        "warningMisinterpretationRate"
      ],
      "additionalProperties": false,
      "properties": {
        "statusComprehensionTime": {
          "type": "object",
          "required": ["p50Seconds", "improvementVsBaselinePercent"],
          "additionalProperties": false,
          "properties": {
            "p50Seconds": {
              "type": "number",
              "minimum": 0
            },
            "improvementVsBaselinePercent": {
              "type": "number"
            }
          }
        },
        "shortfallActionAccuracy": {
          "$ref": "#/$defs/binaryMetric"
        },
        "warningMisinterpretationRate": {
          "$ref": "#/$defs/binaryMetric"
        }
      }
    }
  },
  "$defs": {
    "binaryMetric": {
      "type": "object",
      "required": ["percent", "wilsonInterval95"],
      "additionalProperties": false,
      "properties": {
        "percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "wilsonInterval95": {
          "type": "object",
          "required": ["low", "high"],
          "additionalProperties": false,
          "properties": {
            "low": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "high": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          }
        }
      }
    }
  }
}
